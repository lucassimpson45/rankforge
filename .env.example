# Required for research + script generation
ANTHROPIC_API_KEY=

# ── Voiceover engine ──────────────────────────────────────────────
# "local"  = free Kokoro TTS running on this machine (default)
# "elevenlabs" = paid ElevenLabs API (needs the keys below)
TTS_ENGINE=local

# Local Kokoro voice (good male options: am_michael, am_fenrir, am_puck, am_adam;
# female: af_heart, af_bella). Optional speed multiplier, default 1.0.
TTS_VOICE=am_michael
# TTS_SPEED=1.0

# Only needed if TTS_ENGINE=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Set to 1 to skip voiceover entirely (silent MP4 from clips only).
# SKIP_VOICEOVER=1

# Optional — defaults to claude-sonnet-4-6
# ANTHROPIC_MODEL=
